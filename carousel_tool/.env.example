# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Drive (optional, skip to save locally only) ────
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service_account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=1aBcDeFgHiJkLmNo...

# ── Scanning ──────────────────────────────────────────────
SCAN_URL=https://www.auto.co.il/articles/car-news/
# Comma-separated times in HH:MM format (24h, server local time)
SCAN_TIMES=07:00,14:00

# ── Output ────────────────────────────────────────────────
OUTPUT_DIR=/home/user/carousels
